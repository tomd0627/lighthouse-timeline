# Chrome UX Report (CrUX) History API key
# Get yours free at: https://console.cloud.google.com
# 1. Enable the "Chrome UX Report API"
# 2. Create an API key under APIs & Services → Credentials
# No billing required for personal/portfolio usage.
CRUX_API_KEY=your_google_api_key_here

# Optional: your deployed site URL (used for OG image absolute URLs)
# NEXT_PUBLIC_SITE_URL=https://lighthouse-timeline.netlify.app
